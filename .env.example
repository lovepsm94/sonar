# ─────────────────────────────────────────────────────────────────────────────
# Sonar — biến môi trường (đều là NEXT_PUBLIC_*, inline lúc build cho static export)
# Copy file này thành .env.local để chạy local. Trên Vercel: set ở Project Settings
# → Environment Variables, rồi redeploy. Tất cả ĐỀU TÙY CHỌN — app vẫn chạy nếu bỏ trống.
# ─────────────────────────────────────────────────────────────────────────────

# Domain production (dùng cho canonical, Open Graph, sitemap, robots).
# Bỏ trống → mặc định https://sonar-nine-flame.vercel.app
NEXT_PUBLIC_SITE_URL=https://sonar-nine-flame.vercel.app

# ICE servers (STUN + TURN) cho kết nối WebRTC, dạng JSON array TRÊN MỘT DÒNG.
# Bỏ trống → mặc định Google STUN + Open Relay public TURN (miễn phí, KHÔNG đảm bảo).
# Set biến này khi muốn dùng TURN riêng ổn định hơn (vd Metered free — xem TURN-SETUP.md).
# Dán nguyên cụm iceServers mà Metered cung cấp vào đây, ép về một dòng. Ví dụ:
# NEXT_PUBLIC_ICE_SERVERS=[{"urls":"stun:stun.relay.metered.ca:80"},{"urls":"turn:standard.relay.metered.ca:80","username":"YOUR_USERNAME","credential":"YOUR_CREDENTIAL"},{"urls":"turn:standard.relay.metered.ca:443","username":"YOUR_USERNAME","credential":"YOUR_CREDENTIAL"},{"urls":"turns:standard.relay.metered.ca:443?transport=tcp","username":"YOUR_USERNAME","credential":"YOUR_CREDENTIAL"}]
NEXT_PUBLIC_ICE_SERVERS=
